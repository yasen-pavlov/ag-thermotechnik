---
import '@fontsource-variable/inter';

import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import interLatinExtUrl from '@fontsource-variable/inter/files/inter-latin-ext-wght-normal.woff2?url';
---

<link rel="preload" href={interLatinUrl} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={interLatinExtUrl} as="font" type="font/woff2" crossorigin />

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(7 121 191);
    --aw-color-secondary: rgb(5 100 160);
    --aw-color-accent: rgb(2 132 199);

    --aw-color-text-heading: rgb(15 23 42);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: rgb(7 121 191 / 20%);
    }
  }
</style>

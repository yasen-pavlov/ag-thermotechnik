---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

export async function getStaticPaths() {
  const services = await getCollection('service');
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const metadata = {
  title: service.data.title,
  description: service.data.description,
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">
      {service.data.title}
    </Fragment>
    <Fragment slot="subtitle">
      {service.data.description}
    </Fragment>
  </Hero>

  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </section>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Kontakt aufnehmen',
        href: '/kontakt',
        icon: 'tabler:phone',
      },
      {
        text: 'Alle Dienstleistungen',
        href: '/dienstleistungen',
      },
    ]}
  >
    <Fragment slot="title">Interesse an dieser Dienstleistung?</Fragment>
    <Fragment slot="subtitle">
      Vereinbaren Sie ein unverbindliches Gespräch mit uns — wir beraten Sie gerne.
    </Fragment>
  </CallToAction>
</Layout>

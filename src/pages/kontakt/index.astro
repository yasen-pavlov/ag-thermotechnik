---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';

const metadata = {
  title: 'Kontakt',
  description: 'Kontaktieren Sie A&G Thermotechnik GmbH in Düsseldorf. Telefon: +49 176 38 208 475, E-Mail: info@agthermotechnik.de',
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">
      <span class="text-accent">Kontakt</span>
    </Fragment>
    <Fragment slot="subtitle">
      Wir freuen uns auf Ihre Nachricht. Kontaktieren Sie uns telefonisch, per E-Mail oder über das Kontaktformular.
    </Fragment>
  </Hero>

  <!-- Contact Methods -->
  <Features
    tagline="Kontaktmöglichkeiten"
    title="So erreichen Sie uns"
    items={[
      {
        title: 'Telefon',
        description: '+49 176 38 208 475',
        icon: 'tabler:phone',
        callToAction: { text: 'Jetzt anrufen', href: 'tel:+4917638208475' },
      },
      {
        title: 'E-Mail',
        description: 'info@agthermotechnik.de',
        icon: 'tabler:mail',
        callToAction: { text: 'E-Mail senden', href: 'mailto:info@agthermotechnik.de' },
      },
      {
        title: 'Adresse',
        description: 'Am Trippelsberg 92, 40589 Düsseldorf',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- Contact Form + Map -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Nachricht senden</h2>
        <form
          name="contact"
          method="POST"
          action="/kontakt/danke"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-4"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="Ihr Name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-Mail *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="ihre@email.de"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Telefon (optional)</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="+49 ..."
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Betreff (optional)</label>
            <input
              type="text"
              id="subject"
              name="subject"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="Worum geht es?"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Ihre Nachricht *</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="Beschreiben Sie Ihr Anliegen..."
            ></textarea>
          </div>

          <div class="flex items-start gap-2">
            <input
              type="checkbox"
              id="privacy"
              name="privacy"
              required
              class="mt-1 h-4 w-4 text-primary border-gray-300 rounded focus:ring-primary"
            />
            <label for="privacy" class="text-sm text-gray-600">
              Ich habe die <a href="/datenschutz" class="text-primary hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. *
            </label>
          </div>

          <button
            type="submit"
            class="btn-primary w-full sm:w-auto"
          >
            Absenden
          </button>
        </form>
      </div>

      <!-- Map -->
      <div class="flex flex-col">
        <h2 class="text-2xl font-bold mb-6">Unser Standort</h2>
        <div class="rounded-lg overflow-hidden shadow-md h-80 flex-1 min-h-[320px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2503.14!2d6.85!3d51.17!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sAm+Trippelsberg+92%2C+40589+D%C3%BCsseldorf!5e0!3m2!1sde!2sde!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="A&G Thermotechnik Standort"
          ></iframe>
        </div>

        <div class="mt-6 p-6 bg-gray-50 rounded-lg">
          <h3 class="font-semibold mb-3">A&G Thermotechnik GmbH</h3>
          <p class="text-sm text-gray-600 mb-1">Am Trippelsberg 92</p>
          <p class="text-sm text-gray-600 mb-3">40589 Düsseldorf</p>
          <p class="text-sm text-gray-600 mb-1">
            <strong>Tel:</strong> <a href="tel:+4917638208475" class="text-primary hover:underline">+49 176 38 208 475</a>
          </p>
          <p class="text-sm text-gray-600">
            <strong>E-Mail:</strong> <a href="mailto:info@agthermotechnik.de" class="text-primary hover:underline">info@agthermotechnik.de</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

export async function getStaticPaths() {
  const products = await getCollection('product');
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const metadata = {
  title: product.data.title,
  description: product.data.description,
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">
      {product.data.title}
    </Fragment>
    <Fragment slot="subtitle">
      {product.data.description}
    </Fragment>
  </Hero>

  <section class="mx-auto max-w-4xl px-4 sm:px-6 py-12 md:py-16">
    {product.data.image && (
      <img
        src={product.data.image}
        alt={product.data.title}
        class="w-full rounded-lg shadow-md mb-8 max-h-96 object-cover"
      />
    )}

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    {product.data.features && product.data.features.length > 0 && (
      <div class="mt-12">
        <h2 class="text-2xl font-bold mb-6">Vorteile</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {product.data.features.map((feature) => (
            <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
              <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
              <p class="text-muted">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Beratung vereinbaren',
        href: '/kontakt',
        icon: 'tabler:phone',
      },
      {
        text: 'Alle Produkte',
        href: '/produkte',
      },
    ]}
  >
    <Fragment slot="title">Interesse an diesem Produkt?</Fragment>
    <Fragment slot="subtitle">
      Kontaktieren Sie uns für eine persönliche Beratung. Wir finden die optimale Lösung für Ihre Anforderungen.
    </Fragment>
  </CallToAction>
</Layout>
